APP_NAME=DroneMapper API
DATABASE_URL=postgresql+asyncpg://postgres:postgres@db:5432/dronedata
SYNC_DATABASE_URL=postgresql+psycopg://postgres:postgres@db:5432/dronedata
REDIS_URL=redis://redis:6379/0
ODM_NODE_HOST=localhost
ODM_NODE_PORT=3000
STORAGE_PATH=/data
USE_S3=false
S3_ENDPOINT_URL=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_REGION_NAME=us-east-1
S3_BUCKET=dronedata
MAX_UPLOAD_FILE_SIZE_MB=1024
RATE_LIMIT_UPLOAD=120/minute
RATE_LIMIT_PROCESSING=20/minute
# * = any browser origin (comma-separated list to restrict)
CORS_ORIGINS=*
